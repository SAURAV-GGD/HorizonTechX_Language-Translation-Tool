# ============================================
# LinguaFlow AI — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values
#
# IMPORTANT: Never commit .env.local to git!
# It contains sensitive data like API keys.
# ============================================

# Optional: LibreTranslate API URL (for fallback translation)
# If you self-host LibreTranslate, put your URL here.
# Default: https://libretranslate.com
NEXT_PUBLIC_LIBRETRANSLATE_URL=

# Optional: LibreTranslate API Key
# Only needed if your LibreTranslate instance requires auth
LIBRETRANSLATE_API_KEY=

# Optional: Your email for MyMemory API (increases limit from 5K to 50K chars/day)
NEXT_PUBLIC_MYMEMORY_EMAIL=

# Optional: Google Cloud Translation API Key (premium option)
GOOGLE_TRANSLATE_API_KEY=
