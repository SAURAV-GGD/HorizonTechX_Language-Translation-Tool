# ============================================
# LinguaFlow AI — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.
#
# IMPORTANT: Never commit .env.local to git! It holds secrets.
#
# All translation keys below are SERVER-SIDE secrets (no NEXT_PUBLIC_
# prefix). They are read only inside the /api/translate and /api/detect
# serverless functions and are NEVER exposed to the browser.
# ============================================

# ── PRIMARY: DeepL (Google-Translate-level quality) ──────
# 500,000 free characters / month. Sign up (no card needed):
#   https://www.deepl.com/pro-api
# Free-tier keys end in ":fx" and automatically use the api-free host.
# If this is missing/empty, the app falls back to MyMemory.
DEEPL_API_KEY=your_deepl_api_key_here

# ── FALLBACK: MyMemory (free, raises quota with an email) ─
MYMEMORY_EMAIL=your_email@example.com

# ── LAST RESORT: LibreTranslate (optional) ───────────────
# Defaults to the public instance if LIBRE_TRANSLATE_URL is unset.
LIBRE_TRANSLATE_URL=https://libretranslate.com
# Only needed if your LibreTranslate instance requires auth.
LIBRE_TRANSLATE_API_KEY=
